{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Telegram App",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}/telegram-app"
      },
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Rebuild Inventory Data",
      "type": "shell",
      "command": "node tools/build_inventory.mjs",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}

